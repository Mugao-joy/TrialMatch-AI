FROM python:3.12-slim

WORKDIR /app

# install uv
RUN pip install --upgrade pip && pip install uv

# copy dependency files first for caching
COPY pyproject.toml uv.lock ./

# install dependencies
RUN uv sync --frozen

# copy app files
COPY . .

EXPOSE 8000

CMD ["uv", "run", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]